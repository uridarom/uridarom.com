---
import { getCollection, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id.split('/').pop() },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---
<PageLayout title={project.data.title} activePage="projects">
  <div class="flex flex-col items-center px-6 pb-24">
    <!-- Title -->
    <h1
      class="text-white text-center font-bold mt-12 mb-10"
      style="font-size: clamp(1.6rem, 3vw, 2.2rem); margin-bottom: 6rem;"
    >
      {project.data.title}
    </h1>

    <!-- Content -->
    <div
      class="project-content text-white w-full"
      style="max-width: 900px;"
    >
      <Content />
    </div>
  </div>
</PageLayout>

<style>
  :global(.project-content h2) {
    font-weight: 700;
    font-size: 1.3rem;
    text-transform: uppercase;
    margin-bottom: 1rem;
    opacity: 1
  }
  :global(.project-content p) {
    font-size: 1.1rem;
    margin-bottom: 1.2rem;
    line-height: 1.3;
    opacity: 0.88;
    text-align: left;
    white-space: pre-line
  }
  :global(.project-content ol) {
    padding-left: 3rem;
    list-style: decimal;
    font-size: 1.1rem;
    margin-bottom: 1.2rem;
    line-height: 1.5;
    opacity: 0.88;
    text-align: left;
  }
  :global(.project-content ul) {
    padding-left: 3rem;
    list-style: disc;
    font-size: 1.1rem;
    margin-bottom: 1.2rem;
    line-height: 1.5;
    text-align: left;
  }
  :global(.project-content img) {
    float: right;
    max-width: 40%;
    margin-left: 2rem;
    margin-bottom: 1rem;
  }
  :global(.project-content img + em) {
    display: block;
    text-align: right;
    font-size: 0.72rem;
    opacity: 0.5;
    margin-top: 0.25rem;
    font-style: normal;
  }
</style>
